{
  "name": "hm-newsadmin",
  "private": true,
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env ts-node-dev --transpile-only -r source-map-support/register -r dotenv/config src/server.ts",
    "build": "tsc -p .",
    "start": "cross-env node -r source-map-support/register -r dotenv/config dist/server.js",
    "clean": "rimraf dist",
    "prettier": "prettier -w src"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "prom-client": "^14.1.0",
    "unleash-client": "^6.10.1"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "ip-address": "10.1.1"
  }
}
